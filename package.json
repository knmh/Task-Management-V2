{
    "name": "hediyeh",
    "version": "1.0.0",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": "nodemon src/server.ts",
        "typeorm": "typeorm-ts-node-commonjs",
        "migrate:generate": "typeorm-ts-node-commonjs migration:generate src/migrations/InitialMigration -d src/data-source.ts",
        "migrate:run": "typeorm-ts-node-commonjs migration:run -d src/data-source.ts",
        "migrate:revert": "typeorm-ts-node-commonjs migration:revert -d src/data-source.ts"
    },
    "author": "",
    "license": "ISC",
    "description": "",
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "jsonwebtoken": "^9.0.3",
        "pg": "^8.20.0",
        "reflect-metadata": "^0.2.2",
        "typeorm": "^0.3.28"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/dotenv": "^6.1.1",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.9.1",
        "@types/pg": "^8.20.0",
        "nodemon": "^3.1.14",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3"
    }
}